{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "topics",
    "established_conclusions",
    "open_questions",
    "concepts",
    "policy_events"
  ],
  "properties": {
    "topics": {
      "type": "array",
      "items": { "type": "string" }
    },
    "established_conclusions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "open_questions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "concepts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "policy_events": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "topic",
          "statement",
          "scope",
          "event_type",
          "prior_statement",
          "source_message_ids"
        ],
        "properties": {
          "topic": { "type": "string", "minLength": 1 },
          "statement": { "type": "string", "minLength": 1 },
          "scope": { "type": "string" },
          "event_type": {
            "type": "string",
            "enum": [
              "adopted",
              "revised",
              "withdrawn",
              "reaffirmed",
              "proposed",
              "uncertain"
            ]
          },
          "prior_statement": { "type": "string" },
          "source_message_ids": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
